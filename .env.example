# Contact form -> Telegram bot
# Copy this file to ".env.local" and fill in your values (never commit .env.local).
#
# 1. Create a bot with @BotFather on Telegram -> you get the token.
# 2. Send your bot any message, then open
#    https://api.telegram.org/bot<TOKEN>/getUpdates to find your numeric chat id
#    (or message @userinfobot to get your id).
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Optional: absolute site origin used for metadata / sitemap / OG urls.
NEXT_PUBLIC_SITE_URL=
